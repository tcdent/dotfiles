settings = {
  core = { real_name = "slomp"; user_name = "slomp"; nick = "slomp"; };
  "fe-text" = { actlist_sort = "refnum"; };
  "fe-common/core" = {
    theme = "default";
    autolog = "yes";
    autolog_path = "~/.config/irssi/logs/$tag/$0.log";
    timestamps = "yes";
    show_nickmode_empty = "yes";
  };
  "irc/core" = { alternate_nick = "slomp_"; };
};

# Enable logging
logs = { };

# Hilight your nick (set in startup)
hilights = ( { text = "slomp"; nick = "yes"; word = "yes"; } );

# Ignore joins/parts/quits in busy channels to reduce noise
ignores = (
  {
    level = "JOINS PARTS QUITS";
    channels = ( "#linux", "#python", "#archlinux", "#debian", "#ubuntu" );
  }
);
