# irssi config for Libera.Chat
#
# Credentials are set in ~/.config/irssi/startup (not committed to git).
# Run with: irssi --home=~/.config/irssi
#
# To register a new nick:
#   /connect libera
#   /msg NickServ REGISTER yourpassword your@email.com

servers = (
  {
    address = "irc.libera.chat";
    chatnet = "libera";
    port = "6697";
    use_tls = "yes";
    tls_verify = "yes";
    # NOTE: autoconnect is OFF here because we connect via ~/.irssi/startup
    # AFTER configuring SASL. This ensures authentication happens before
    # joining any channels. See setup instructions above.
    autoconnect = "no";
  }
);

chatnets = { libera = { type = "IRC"; }; };

