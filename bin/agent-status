#!/usr/bin/env bash
# agent-status: unified pane-state report for all registered agents.
#
# Scans tmux for panes running claude whose pane_title contains a
# registered identity (@<domain>). Reports each agent's current state:
# idle, working, blocked (approval/menu/survey/other), or exited.
#
# "Blocked" means the input prompt is not available — the agent needs
# interaction or is stuck on a dialog. Specific block types are reported
# when the signature is recognized; unrecognized blocks report as
# "blocked (unknown)".
#
# Usage:
#   agent-status                        Text summary, all registered agents
#   agent-status --json                 One ndjson record per agent
#   agent-status <identity>             Single agent lookup
#   agent-status <identity> --json      Single agent, json
#   agent-status -h | --help

set -euo pipefail

die() { echo "error: $*" >&2; exit 1; }

# --- Identity extraction (from agent-message) ---

identity_from_title() {
  printf '%s\n' "$1" | grep -oE '[a-zA-Z0-9._-]+@[a-zA-Z0-9._-]+' | head -1 || true
}

# --- Pane-state predicates (from agent-message + agent-restart + agent-blocked-poll) ---

# Capture pane content, strip trailing blanks. Shared by all predicates.
capture_stripped() {
  local pane="$1"
  local content
  content=$(tmux capture-pane -t "$pane" -p 2>/dev/null) || return 1
  printf '%s\n' "$content" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }'
}

# Empty prompt: live input line is ❯ + NBSP + (EOL or space).
is_empty_prompt() {
  local content="$1"
  printf '%s\n' "$content" | tail -10 | grep -qP '^❯\x{00a0}($| )'
}

# Approval dialog: "Do you want to proceed?" + menu selector.
is_approval_prompt() {
  local content="$1"
  local tail30
  tail30=$(printf '%s\n' "$content" | tail -30)
  if printf '%s\n' "$tail30" | grep -qF 'Do you want to proceed?' &&
     printf '%s\n' "$tail30" | grep -qP '^ \xe2\x9d\xaf [0-9]+\.'; then
    return 0
  fi
  return 1
}

# Extract approval section header (e.g. "Bash command", "Write(path)")
extract_approval_section() {
  local content="$1"
  printf '%s\n' "$content" | tail -30 | awk '
    { lines[NR] = $0 }
    END {
      q = 0
      for (i = NR; i >= 1; i--)
        if (lines[i] ~ / Do you want to proceed\?/) { q = i; break }
      if (!q) exit 1
      i = q - 1
      while (i >= 1 && lines[i] ~ /^[[:space:]]*$/) i--
      # Skip any 1-space warning lines (Bug: security-reasoning lines)
      while (i >= 1 && lines[i] ~ /^ [^ ]/ && lines[i] !~ /^ [A-Z][a-z]+ *(command|file|\()/) i--
      if (i >= 1 && lines[i] ~ /^   [^ ]/) {
        while (i >= 1 && lines[i] ~ /^   /) i--
        while (i >= 1 && lines[i] ~ /^[[:space:]]*$/) i--
      }
      if (i >= 1 && lines[i] ~ /^ [^ ]/) {
        s = lines[i]; sub(/^ /, "", s); sub(/[[:space:]]+$/, "", s)
        print s
      }
    }
  '
}

# Resume-from-summary menu.
is_resume_menu() {
  local content="$1"
  printf '%s\n' "$content" | tail -15 | grep -qF 'Resume from summary'
}

# Feedback survey.
is_feedback_survey() {
  local content="$1"
  printf '%s\n' "$content" | tail -15 | grep -qF 'How is Claude doing this session?'
}

# --- State classifier ---
# Returns: idle | working | approval:<section> | menu | survey | blocked | exited

classify_pane() {
  local pane="$1"
  local cmd
  cmd=$(tmux display-message -t "$pane" -p '#{pane_current_command}' 2>/dev/null || true)

  if [[ "$cmd" != "claude" ]]; then
    echo "exited"
    return
  fi

  local content
  content=$(capture_stripped "$pane") || { echo "exited"; return; }

  if is_empty_prompt "$content"; then
    echo "idle"
    return
  fi

  if is_approval_prompt "$content"; then
    local section
    section=$(extract_approval_section "$content" 2>/dev/null || true)
    if [[ -n "$section" ]]; then
      echo "approval:$section"
    else
      echo "approval"
    fi
    return
  fi

  if is_resume_menu "$content"; then
    echo "menu"
    return
  fi

  if is_feedback_survey "$content"; then
    echo "survey"
    return
  fi

  # Claude is running but not at any recognized prompt/dialog — working or
  # in an unrecognized blocking state. Both mean "input prompt unavailable".
  # We report as "working" since that's the common case (mid-tool-use,
  # thinking, composing). If it's actually stuck on an unrecognized dialog,
  # the operator will see it's not making progress over time.
  echo "working"
}

# --- Output ---

emit_text() {
  local identity="$1" pane="$2" state="$3"
  printf '  %-40s %-12s %s\n' "$identity" "$pane" "$state"
}

emit_json() {
  local identity="$1" pane="$2" state="$3"
  local state_base="${state%%:*}"
  local detail=""
  [[ "$state" == *:* ]] && detail="${state#*:}"

  IDENTITY="$identity" PANE="$pane" STATE_BASE="$state_base" DETAIL="$detail" \
    python3 -c '
import json, os
d = {"identity": os.environ["IDENTITY"], "pane": os.environ["PANE"], "state": os.environ["STATE_BASE"]}
detail = os.environ["DETAIL"]
if detail:
    d["detail"] = detail
print(json.dumps(d))
'
}

# --- Main ---

JSON=0
TARGET=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON=1 ;;
    -h|--help|help)
      cat <<'HELPEOF'
Usage:
  agent-status                        All registered agents, text
  agent-status --json                 All registered agents, ndjson
  agent-status <identity>             Single agent
  agent-status <identity> --json      Single agent, json

States:
  idle           Empty prompt, ready for input
  working        Mid-tool-use, thinking, or composing
  approval       At a permission dialog (detail: tool section header)
  menu           At the resume-from-summary menu
  survey         At the feedback survey
  exited         Pane exists but claude not running

Exit 0 always (status is informational, not pass/fail).
HELPEOF
      exit 0
      ;;
    -*) die "unknown flag: $1" ;;
    *) TARGET="$1" ;;
  esac
  shift
done

# Iterate registered agents (claude panes with identity in pane_title)
ANY=0
while IFS=$'\t' read -r addr cmd title; do
  [[ "$cmd" != "claude" ]] && continue
  identity=$(identity_from_title "$title")
  [[ -z "$identity" ]] && continue

  # If targeting a specific agent, skip non-matches
  if [[ -n "$TARGET" ]]; then
    if [[ "$TARGET" != "$identity" && "$TARGET" != "${identity%@*}" ]]; then
      continue
    fi
  fi

  state=$(classify_pane "$addr")

  if [[ $JSON -eq 1 ]]; then
    emit_json "$identity" "$addr" "$state"
  else
    emit_text "$identity" "$addr" "$state"
  fi
  ANY=1
done < <(tmux list-panes -a -F "#{session_name}:#{window_index}.#{pane_index}	#{pane_current_command}	#{pane_title}")

if [[ $ANY -eq 0 && -n "$TARGET" ]]; then
  die "no registered agent found for '$TARGET'"
fi

exit 0
