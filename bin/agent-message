#!/usr/bin/env bash
# agent-message: messaging primitives for Claude Code instances in tmux
#
# Usage:
#   agent-message whoami                           # print your identity
#   agent-message dir [workspace|global|network]   # list panes (default: workspace)
#   agent-message send <target> <message>          # send a message to a peer
#
# Targets may be agent identities (<id>@a10k.internal), tmux addresses
# (session:window.pane), or the two@a10k.co alias. Cross-host routing is
# driven by ~/.config/agent-message/hosts; see full --help for scope details.

set -euo pipefail

HOSTS_FILE="${AGENT_MESSAGE_HOSTS:-$HOME/.config/agent-message/hosts}"

# --- Helpers ---

die() { echo "error: $*" >&2; exit 1; }

# --- Cross-host routing ---
#
# The hosts file lists REMOTE hosts only — one entry per line, mapping
# identity-domain suffixes to the user@host[:port] that owns them:
#
#   <user@host[:port]>  <domain1> [domain2 ...]
#
# Examples:
#   slomp@host2.local         otherdomain.internal
#   slomp@host3.local:2222    third.internal                # nonstandard SSH port
#
# By convention the local host is never in the file. If a target's domain
# matches an entry, delivery takes the SSH branch; otherwise resolution
# falls through to local lookup. No local-vs-remote detection is needed.

declare -A HOST_FOR_DOMAIN=()

load_hosts() {
  [[ ! -r "$HOSTS_FILE" ]] && return 0
  local line user_host rest d
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue

    read -r user_host rest <<< "$line"
    [[ -z "$user_host" || -z "$rest" ]] && continue
    [[ "$user_host" != *"@"* ]] && continue

    for d in $rest; do
      HOST_FOR_DOMAIN["$d"]="$user_host"
    done
  done < "$HOSTS_FILE"
}

load_hosts

get_self() {
  [[ -z "${TMUX_PANE:-}" ]] && die "not running inside tmux"
  tmux display-message -p -t "$TMUX_PANE" "#{session_name}:#{window_index}.#{pane_index}"
}

get_session() {
  [[ -z "${TMUX_PANE:-}" ]] && die "not running inside tmux"
  tmux display-message -p -t "$TMUX_PANE" "#{session_name}"
}

# Forward lookup: identity (email) → tmux address
# Scans pane_title across all panes; returns empty string if no match.
lookup_identity() {
  local id="$1"
  local addr=""
  while IFS=$'\t' read -r a t; do
    if [[ "$t" == *"$id"* ]]; then
      addr="$a"
      break
    fi
  done < <(tmux list-panes -a -F "#{session_name}:#{window_index}.#{pane_index}	#{pane_title}")
  echo "$addr"
}

# Extract an agent identity from a pane_title string; empty if none.
# The `|| true` swallows grep's non-zero exit when no match is found
# (otherwise set -euo pipefail would abort the caller).
identity_from_title() {
  echo "$1" | grep -oE '[a-zA-Z0-9._-]+@a10k\.internal' | head -1 || true
}

# Reverse lookup: tmux address → identity (email).
#
# Mirrors resolve_target's branch structure:
#   1. Explicit address aliases (e.g. two:2.1 → two@a10k.co). Kept in sync
#      with the forward aliases in resolve_target — any new cross-org entry
#      lands in both places.
#   2. Standard path: extract @a10k.internal identity from pane_title via
#      identity_from_title.
# Returns empty string if neither matches.
reverse_identity() {
  local target="$1"

  # Resolve to session:window.pane form for stable address matching,
  # regardless of whether caller passed $TMUX_PANE or a pre-resolved address.
  local addr
  addr=$(tmux display-message -p -t "$target" "#{session_name}:#{window_index}.#{pane_index}" 2>/dev/null || true)

  case "$addr" in
    two:2.1) echo "two@a10k.co"; return 0 ;;
  esac

  local title
  title=$(tmux display-message -p -t "$target" "#{pane_title}" 2>/dev/null || true)
  identity_from_title "$title"
}

# Prefer the sender's identity for attribution; fall back to tmux address if
# the pane isn't tagged with an identity.
get_self_identity() {
  [[ -z "${TMUX_PANE:-}" ]] && die "not running inside tmux"
  local id
  id=$(reverse_identity "$TMUX_PANE")
  if [[ -n "$id" ]]; then
    echo "$id"
  else
    get_self
  fi
}

# Escape a message for safe delivery via tmux send-keys.
# Returns non-zero if the message contains sequences we can't safely escape.
escape_message() {
  local msg="$1"

  # Reject messages containing raw escape sequences (tmux control codes)
  if [[ "$msg" =~ $'\e' ]]; then
    die "message contains escape sequences that cannot be safely sent"
  fi

  # tmux send-keys with a quoted string handles most things fine.
  # We need to escape:
  #   - backslashes (double them)
  #   - double quotes (backslash-escape)
  #   - dollar signs (prevent shell expansion in recipient)
  #   - backticks (prevent command substitution)
  msg="${msg//\\/\\\\}"
  msg="${msg//\"/\\\"}"
  msg="${msg//\$/\\\$}"
  msg="${msg//\`/\\\`}"

  printf '%s' "$msg"
}

# Check whether a target pane is ready to receive a message.
#
# For Claude panes, we look for the text entry prompt (❯ followed by an
# empty/whitespace-only line). This is the only state where the agent is
# ready to accept input. Any other state — approval dialogs, mid-tool-use,
# user composing — means the agent is busy.
#
# Non-Claude panes are always considered ready.
#
# TODO: Consider distinguishing "user is composing" from "agent is busy"
# TODO: Test behavior when agent is mid-tool-use with auto-approve
check_target_ready() {
  local target="$1"

  local target_cmd
  target_cmd=$(tmux display-message -t "$target" -p "#{pane_current_command}")

  # Only check Claude panes — non-Claude panes are always ready
  [[ "$target_cmd" != "claude" ]] && return 0

  # Capture the visible pane, strip trailing blank lines, check the last 10
  # lines for the prompt canary.
  #
  # Byte signatures:
  #   Empty prompt (ready):   e2 9d af  c2 a0  [20|0a]  → ❯ + NBSP + (space or EOL)
  #   User composing (busy):  e2 9d af  c2 a0  [text]   → ❯ + NBSP + typed chars
  #   Sent message (history): e2 9d af  20     [text]   → ❯ + regular space + text
  #
  # Pattern: ^❯\x{00a0}($| )
  #   - Matches only the live input prompt (NBSP distinguishes from history)
  #   - EOL or space after NBSP = empty prompt, ready to receive
  #   - Text after NBSP = user is composing, block delivery
  #   - Convention: a leading space in user input is treated as "empty" (allows
  #     agents to deliver even when user has started but wants to yield)
  local pane_content
  pane_content=$(tmux capture-pane -t "$target" -p | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')

  if echo "$pane_content" | tail -10 | grep -qP '^❯\x{00a0}($| )'; then
    return 0
  fi

  die "target is not ready to receive - no data was sent - backoff and try again shortly"
}

# Resolve a target address to a concrete tmux address, or to a REMOTE sentinel
# indicating the identity lives on another host.
#
# Accepts:
#   session:window.pane            — tmux address, pass-through (always local)
#   <id>@<domain>                  — if the domain routes to a non-local host
#                                    per the hosts file, returns
#                                    REMOTE:<user@host>; otherwise falls
#                                    through to local lookup
#   two@a10k.co                    — hardcoded within-host alias → two:2.1
#   <id>@a10k.internal             — agent identity looked up by pane_title
resolve_target() {
  local target="$1"

  # Already a tmux address — always local
  if [[ "$target" =~ ^[^@]+:[0-9]+\.[0-9]+$ ]]; then
    echo "$target"
    return 0
  fi

  # Cross-host routing: if the target's domain has a hosts-file entry, the
  # target lives on another machine by convention (local is never in the
  # file). Runs BEFORE local aliases and identity lookup so we don't try to
  # resolve an identity against our tmux server when it lives elsewhere.
  if [[ "$target" == *"@"* ]]; then
    local domain="${target#*@}"
    local user_host="${HOST_FOR_DOMAIN[$domain]:-}"
    if [[ -n "$user_host" ]]; then
      echo "REMOTE:$user_host"
      return 0
    fi
  fi

  # Hardcoded local aliases — describe within-host shortcuts. They only
  # fire when the domain wasn't in the hosts file (i.e. routes locally).
  case "$target" in
    two@a10k.co) echo "two:2.1"; return 0 ;;
  esac

  # Agent identity — look up the pane tagged with this identity.
  # pane_title is updated by Claude Code's auto-title mechanism from the session
  # name, so renamed panes are discoverable (e.g. "⠂ mgmt.arch@a10k.internal").
  if [[ "$target" == *"@a10k.internal" ]]; then
    local addr
    addr=$(lookup_identity "$target")
    [[ -n "$addr" ]] || die "no live pane found for identity '$target'"
    echo "$addr"
    return 0
  fi

  die "unrecognized target format: '$target' (expected session:window.pane, <id>@a10k.internal, or two@a10k.co)"
}

# --- Commands ---

cmd_whoami() {
  get_self_identity
}

cmd_dir() {
  local scope="${1:-workspace}"

  if [[ "$scope" == "network" ]]; then
    cmd_dir_network
    return 0
  fi

  # workspace/global both rely on a local tmux server. self is only defined
  # when we're running inside tmux (when `dir network` fans out to this host
  # over SSH, there's no TMUX_PANE — leaving self empty disables the "(you)"
  # marker, which is correct from the remote caller's perspective).
  local self=""
  [[ -n "${TMUX_PANE:-}" ]] && self=$(get_self)

  local pane_list
  case "$scope" in
    workspace)
      [[ -z "${TMUX_PANE:-}" ]] && die "workspace scope requires tmux context"
      local session
      session=$(get_session)
      pane_list=$(tmux list-panes -s -t "$session" \
        -F "#{session_name}:#{window_index}.#{pane_index}	#{pane_current_command}	#{pane_title}")
      ;;
    global)
      pane_list=$(tmux list-panes -a \
        -F "#{session_name}:#{window_index}.#{pane_index}	#{pane_current_command}	#{pane_title}")
      ;;
    *)
      die "unknown scope: $scope (use 'workspace', 'global', or 'network')"
      ;;
  esac

  [[ -z "$pane_list" ]] && die "no panes found"

  while IFS=$'\t' read -r addr cmd title; do
    local marker=""
    [[ "$addr" == "$self" ]] && marker=" (you)"

    # Prefer identity when the pane is tagged with one; fall back to tmux address.
    local display_addr
    display_addr=$(identity_from_title "$title")
    [[ -z "$display_addr" ]] && display_addr="$addr"

    printf "  %-36s %s%s\n" "$display_addr" "$cmd" "$marker"
  done <<< "$pane_list"
}

# Re-emit stdin as dir rows under a host-label column. Strips the leading
# two-space indent cmd_dir produces so alignment is consistent.
prefix_rows() {
  local host_label="$1"
  local line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    printf '  %-10s  %s\n' "$host_label" "${line#  }"
  done
}

# Emit a remote host's panes with a host-label prefix. Endpoint may be
# user@host or user@host:port. On any non-zero SSH exit (ssh-level failure
# OR remote agent-message error), emit a single (unreachable: ...) line and
# return 0 so one bad host doesn't sink the whole directory.
dump_remote_dir() {
  local endpoint="$1"
  local sshtarget="$endpoint"
  local port=""
  if [[ "$endpoint" == *:* ]]; then
    sshtarget="${endpoint%:*}"
    port="${endpoint##*:}"
  fi

  # Label is the hostname without user@ or :port or trailing .local.
  local host_label="${sshtarget#*@}"
  host_label="${host_label%.local}"

  local ssh_opts=(-o BatchMode=yes -o ConnectTimeout=5)
  [[ -n "$port" ]] && ssh_opts+=(-p "$port")

  local rc=0
  local dir_out
  dir_out=$(ssh "${ssh_opts[@]}" "$sshtarget" agent-message dir global 2>&1) || rc=$?
  if [[ $rc -ne 0 ]]; then
    local errtxt
    errtxt=$(printf '%s\n' "$dir_out" | head -1)
    printf '  %-10s  (unreachable: %s)\n' "$host_label" "${errtxt:-exit $rc}"
    return 0
  fi

  printf '%s\n' "$dir_out" | prefix_rows "$host_label"
}

# 'dir network' — third-tier scope. Emits the local tmux server first (so
# the "(you)" marker anchors on our pane), then fans out to every remote
# host in the hosts file. Local is never in the file by convention, so no
# dedup is needed.
cmd_dir_network() {
  local local_label
  local_label=$(hostname)
  local_label="${local_label%.local}"
  local_label="${local_label,,}"

  cmd_dir global | prefix_rows "$local_label"

  local uh
  declare -A SEEN=()
  for uh in "${HOST_FOR_DOMAIN[@]}"; do
    [[ -n "${SEEN[$uh]:-}" ]] && continue
    SEEN[$uh]=1
    dump_remote_dir "$uh"
  done
}

cmd_send() {
  # --raw: the message already carries a [from->to] envelope built by the
  # origin host, so don't re-envelope and don't consult local identity. Used
  # internally for the SSH hop in cross-host delivery; not a user-facing flag.
  local raw=0
  if [[ "${1:-}" == "--raw" ]]; then
    raw=1
    shift
  fi

  local target="${1:-}"
  local message="${2:-}"

  [[ -z "$target" ]] && die "usage: agent-message send <addr> <message>"
  [[ -z "$message" ]] && die "usage: agent-message send <addr> <message>"

  # Preserve what the sender typed for the envelope's "to" field — we want
  # recipients to see who they were addressed as, not just where they live.
  local target_display="$target"

  # Resolve identity / alias to tmux address (or REMOTE sentinel) for delivery
  target=$(resolve_target "$target")

  # Remote branch: build the envelope locally (where the sender's identity
  # lives), then hand the fully-formed envelope to the remote via SSH with
  # --raw so it delivers the message as-is.
  if [[ "$target" == REMOTE:* ]]; then
    # A --raw invocation that resolves remote means a host in the chain has a
    # stale hosts file — abort rather than loop.
    [[ $raw -eq 1 ]] && die "routing loop: --raw message resolved to remote host '$target'"

    # Endpoint may be user@host or user@host:port. Split port out for ssh -p.
    local remote_endpoint="${target#REMOTE:}"
    local remote_sshtarget="$remote_endpoint"
    local remote_port=""
    if [[ "$remote_endpoint" == *:* ]]; then
      remote_sshtarget="${remote_endpoint%:*}"
      remote_port="${remote_endpoint##*:}"
    fi

    local self
    self=$(get_self_identity)
    local envelope="[$self->$target_display] $message"

    # Build the remote command with printf %q so the envelope survives SSH's
    # shell-on-both-sides argument handling unmolested.
    local remote_cmd
    remote_cmd=$(printf 'agent-message send --raw %q %q' "$target_display" "$envelope")

    local ssh_opts=(-o BatchMode=yes -o ConnectTimeout=5)
    [[ -n "$remote_port" ]] && ssh_opts+=(-p "$remote_port")

    local rc=0
    local ssh_out
    ssh_out=$(ssh "${ssh_opts[@]}" "$remote_sshtarget" "$remote_cmd" 2>&1) || rc=$?

    if [[ $rc -ne 0 ]]; then
      # ssh exits 255 on its own failures (connection refused, auth, DNS);
      # anything else is the remote agent-message's exit code.
      if [[ $rc -eq 255 ]]; then
        die "could not reach host '$remote_endpoint' (ssh exit 255): $ssh_out"
      fi
      [[ -n "$ssh_out" ]] && echo "$ssh_out" >&2
      die "remote delivery failed on '$remote_endpoint' (exit $rc)"
    fi
    return 0
  fi

  # Local delivery
  if ! tmux has-session -t "${target%%:*}" 2>/dev/null; then
    die "session '${target%%:*}' not found"
  fi

  if ! tmux display-message -t "$target" -p "" 2>/dev/null; then
    die "pane '$target' not found"
  fi

  check_target_ready "$target"

  # Build the payload: --raw passes through, normal path prepends a
  # [self->target] envelope.
  local payload
  if [[ $raw -eq 1 ]]; then
    payload="$message"
  else
    local self
    self=$(get_self_identity)
    payload="[$self->$target_display] $message"
  fi

  local escaped
  escaped=$(escape_message "$payload")

  tmux send-keys -t "$target" "$escaped" Enter

  # Brief pause to let tmux process the message before the safety enter.
  # Without this, the trailing enter can arrive before the message is fully
  # rendered in the target pane, causing submission to fail on long messages.
  sleep 0.2

  tmux send-keys -t "$target" "" Enter
}

# --- Main ---

case "${1:-}" in
  whoami) cmd_whoami ;;
  dir)    cmd_dir "${2:-workspace}" ;;
  send)   shift; cmd_send "$@" ;;
  -h|--help|help|"")
    cat <<EOF
Usage:
  agent-message whoami                             Print your identity (or tmux address if untagged)
  agent-message dir [workspace|global|network]     List panes — identity shown when present, tmux address otherwise
  agent-message send <target> <message>            Send a message to a peer

Scopes:
  workspace  current tmux session only
  global     every pane on the local tmux server
  network    every pane on every host in the hosts file (cross-host fan-out)

Address formats accepted by send:
  <identity>@a10k.internal                 agent identity (preferred)
  session:window.pane                      tmux address (e.g. mgmt:2.7)
  two@a10k.co                              cross-org alias

Examples:
  agent-message send mgmt.design@a10k.internal "can you review ticket ABC-42?"
  agent-message send mgmt:2.4 "tail the build log and report back"
EOF
    ;;
  *)
    die "unknown command: $1"
    ;;
esac
